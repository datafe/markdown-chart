{
  "name": "@datafe-open/markdown-chart",
  "version": "0.1.0",
  "description": "Framework-neutral registry and lifecycle controller for JSON charts in Markdown",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/datafe/markdown-chart.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/datafe/markdown-chart#readme",
  "bugs": {
    "url": "https://github.com/datafe/markdown-chart/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "LICENSES",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
