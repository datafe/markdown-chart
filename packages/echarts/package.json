{
  "name": "@datafe/markdown-chart-echarts",
  "version": "0.1.0",
  "description": "Secure JSON-only ECharts renderer for Markdown Chart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/datafe/markdown-chart.git",
    "directory": "packages/echarts"
  },
  "homepage": "https://github.com/datafe/markdown-chart#readme",
  "bugs": {
    "url": "https://github.com/datafe/markdown-chart/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "LICENSES",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external @datafe/markdown-chart --external echarts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@datafe/markdown-chart": "workspace:*"
  },
  "peerDependencies": {
    "echarts": ">=5.5 <7"
  },
  "devDependencies": {
    "echarts": "^6.0.0"
  }
}
