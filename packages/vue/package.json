{
  "name": "@datafe-open/markdown-chart-vue",
  "version": "0.0.0",
  "description": "Vue 3 lifecycle adapter for Markdown Chart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/datafe/markdown-chart.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/datafe/markdown-chart#readme",
  "bugs": {
    "url": "https://github.com/datafe/markdown-chart/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external vue --external markdown-it --external @datafe-open/markdown-chart --external @datafe-open/markdown-chart-echarts --external @datafe-open/markdown-chart-markdown-it",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@datafe-open/markdown-chart": "workspace:*",
    "@datafe-open/markdown-chart-echarts": "workspace:*",
    "@datafe-open/markdown-chart-markdown-it": "workspace:*",
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.0"
  },
  "peerDependencies": {
    "echarts": ">=5.5 <7",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "vue": "^3.5.13"
  }
}
