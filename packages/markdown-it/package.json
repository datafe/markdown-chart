{
  "name": "@datafe/markdown-chart-markdown-it",
  "version": "0.1.0",
  "description": "Safe markdown-it placeholder adapter for Markdown Chart",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external markdown-it --external @datafe/markdown-chart",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@datafe/markdown-chart": "workspace:*",
    "@types/markdown-it": "^14.1.2"
  },
  "peerDependencies": {
    "markdown-it": ">=13 <15"
  },
  "devDependencies": {
    "markdown-it": "^14.1.0"
  }
}
