{
  "name": "@datafe/markdown-chart-react",
  "version": "0.1.0",
  "description": "react-markdown adapter for Markdown Chart",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react --external react-markdown --external @datafe/markdown-chart --external @datafe/markdown-chart-echarts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@datafe/markdown-chart": "workspace:*",
    "@datafe/markdown-chart-echarts": "workspace:*"
  },
  "peerDependencies": {
    "echarts": ">=5.5 <7",
    "react": "^18.0.0 || ^19.0.0",
    "react-markdown": "^9.0.0 || ^10.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0"
  }
}
